{
  "$schema": "https://example.com/claude-code-settings.schema.json",
  "enabledMcpjsonServers": [
    "fusebase-dashboards",
    "fusebase-gate"
  ],
  "_comment_about_this_file": [
    "This is an EXAMPLE settings file for Claude Code shipped with Fusebase Flow.",
    "To enable: copy to `.claude/settings.json` and customize the python interpreter path.",
    "Hooks read JSON events from stdin and write decisions to stdout — see",
    "hooks/README.md and hooks/flow_hook_event.schema.json.",
    "Flow hook commands use $CLAUDE_PROJECT_DIR (set by Claude Code at runtime) so they resolve from any subdir.",
    "This example keeps CLI Stop hooks and Flow lifecycle hooks together additively.",
    "Stop hooks mirror the FuseBase CLI 0.25.9 wired set (run-lint-on-stop.sh, run-typecheck-on-stop.sh, quality-check-apps.js) followed by Flow stop.py. The merge is preserve-only: it appends stop.py and keeps every existing CLI Stop hook; it never static-injects a hook from a name (an older-CLI project that still wires run-typecheck-apps.js keeps it).",
    "PreToolUse uses the current hookSpecificOutput.permissionDecision style."
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/session_start.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/user_prompt_submit.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/pre_tool_use.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/post_tool_use.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-lint-on-stop.sh",
            "statusMessage": "Running lint before allowing completion…",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-typecheck-on-stop.sh",
            "statusMessage": "Running typecheck before allowing completion…",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/quality-check-apps.js",
            "statusMessage": "Running app quality check...",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/stop.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/handlers/pre_compact.py"
          }
        ]
      }
    ]
  },
  "_notes": {
    "permissionDecision_format": "PreToolUse handler returns hookSpecificOutput.permissionDecision: 'allow' | 'deny' | 'ask' along with permissionDecisionReason.",
    "windows_users": "Replace 'python3' with the python launcher path (e.g., 'py' or 'C:\\\\Python313\\\\python.exe').",
    "CLAUDE_PROJECT_DIR": "Claude Code sets $CLAUDE_PROJECT_DIR to the project root at runtime (the legacy ${PROJECT_DIR} placeholder was never substituted by Claude Code; settings-json-merge.py still normalizes it in old installs).",
    "manual_for_side_effects": "Skills with `invocation: manual-for-side-effects` (release-deploy-reporting) should not be auto-invoked. Operator triggers explicitly."
  }
}
