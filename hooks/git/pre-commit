#!/usr/bin/env bash
# Fusebase Flow — pre-commit git hook
# fusebase-flow-managed-hook: v1
#
# Runs before each commit. Defends FR-07 (worker-undisturbed), FR-12 (secrets),
# FR-13 (lint+typecheck), and FR-25 (module-size ratchet). Original Fusebase
# Flow content; clean-room.
#
# Install: bash hooks/local/install-git-hooks.sh
#
# Bypass: NEVER use --no-verify. Real secret flagged => rotate + `git reset HEAD --
# <file>` to unstage; never whitelist it (disables a pattern globally, breaks the
# scanner's own fixtures 10/11). False positive => fix the pattern.
# Known scan-scope limits (docs/compatibility.md § Secret-scan): designed-token
# files are path-excluded; PreToolUse self-trips when an agent writes full
# secret-patterns.yml content.

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
    echo "[fusebase-flow:pre-commit] not in a git repo; skipping" >&2
    exit 0
fi

cd "$ROOT" || exit 0

# ENV SANITIZATION (T30, security floor): scrub every python-influencing env var ONCE,
# before any python invocation below. ANY python call running with a mutable/inherited
# PYTHONPATH/startup surface is a sitecustomize-injection point: an attacker who exports
# `PYTHONPATH=$ROOT/hooks` + drops an untracked hooks/sitecustomize.py can run
# `os._exit(0)` (or forge a verdict file) at interpreter startup, BEFORE any check.
# T29 hardened §2/§3 with `-S`, but the §3 PREP step inherited PYTHONPATH and ran plain
# python3 — the live PoC bypass. Unsetting these here means no inherited value reaches
# ANY python invocation; each invocation additionally passes `-S` + an explicit,
# trusted-only PYTHONPATH (defense in depth). PYTHONNOUSERSITE=1 also blocks the user
# site-dir startup path even for any incidental non-`-S` python a sub-tool might spawn.
# PYTHONSAFEPATH=1 (T32, defense-in-depth): on Python 3.11+ the interpreter NEVER prepends
# the script dir / CWD / '' to sys.path, so a `python3 -S -` (stdin) heredoc can no longer
# import a repo-root pathlib.py/yaml.py shadow ahead of stdlib/site. Harmless/ignored on
# <3.11. Belt-and-suspenders with the primary T32 fix (§2/§3 mains now run as FILE scripts
# from the trusted temp dir, whose script-dir is the trusted dir and never the CWD).
unset PYTHONPATH PYTHONSTARTUP PYTHONHOME 2>/dev/null || true
export PYTHONNOUSERSITE=1
export PYTHONSAFEPATH=1

# 1. Reject likely secret files in staged changes.
SECRETS_REGEX='\.env$|\.env\.[^\.]*$|credentials\.json$|/secrets/|\.pem$|\.key$|\.netrc$'
STAGED_PATHS="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"
SECRET_HITS="$(echo "$STAGED_PATHS" | grep -E "$SECRETS_REGEX" || true)"
if [ -n "$SECRET_HITS" ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — secret-like files staged:" >&2
    echo "$SECRET_HITS" | sed 's/^/  /' >&2
    echo "Per FR-12: never commit secrets. Unstage with \`git reset HEAD -- <file>\` and rotate if leaked." >&2
    exit 1
fi

# 2. Secret content scan (FR-12): ONLY added (+) lines, designed-token files path-excluded
#    (D-A1 — secret-patterns.yml self-trip + whitelist trap). scan() semantics UNCHANGED
#    (hooks/tests/fixtures 10/11 call scan() directly).
#
#    TRUSTED-HEAD SECRET SCANNER (T31, UNCONDITIONAL): the scanner CODE
#    (staged_secret_scan.py + secret_scanner.py + its shared deps) AND its patterns data
#    (policies/secret-patterns.yml) are THEMSELVES fusebase_flow_internals — the mutable
#    working tree cannot be trusted to run its own secret gate. T29/T30 added `-S` + an
#    env scrub (no startup-file / inherited-PYTHONPATH injection), but the SCRIPT + its
#    PATTERNS were still the working tree: an UNSTAGED tamper of staged_secret_scan.py
#    (make it `return 0`) OR of secret-patterns.yml (empty `patterns:`) => "no secrets"
#    => a real secret in the staged changeset commits unguarded. Same mutable-Python-load
#    class as the §3 self-tamper (T28-T30), applied to the secret scanner. Closed here by
#    running §2 from the COMMITTED (HEAD) scanner + patterns, extracted into a temp package
#    and imported under `-S` with an isolated PYTHONPATH (the trusted temp dir, never
#    $ROOT/hooks). It scans the STAGED changeset (git diff --cached — unchanged; the
#    content being committed). The env is already scrubbed at the hook top (T30).
#    GIT-BASED TRUSTED-vs-FALLBACK (shell-decided, like §3/T30): if HEAD carries the
#    scanner => ALWAYS trusted (a working-tree tamper cannot run). Fall back to the
#    working-tree scanner (under `-S`, with a note) ONLY when git proves HEAD genuinely
#    LACKS it (true first-adoption). A transient git error => fail closed.
if command -v python3 >/dev/null 2>&1; then
    # SEC_IMPORT_DIR = where the scanner `shared` package is imported from;
    # SEC_TRUSTED_PATTERNS = the trusted patterns yaml to seed the loader cache with
    # (empty => bootstrap fallback, scanner reads the working-tree patterns).
    SEC_IMPORT_DIR="$ROOT/hooks"
    SEC_TRUSTED_PATTERNS=""
    SEC_TMP=""
    # Sentinels: the scanner code + its patterns data. The SHELL decides trusted-vs-fallback
    # via `git ls-tree HEAD` (unforgeable — no python/startup file can influence it). rc0+
    # non-empty => present; rc0+empty => genuinely absent (first-adoption); rc!=0 => transient
    # git error => fail closed. (staged_secret_scan -> secret_scanner -> {audit_logger,
    # policy_loader}; policy_loader reads secret-patterns.yml.)
    SEC_SENTINELS="hooks/shared/__init__.py hooks/shared/staged_secret_scan.py hooks/shared/secret_scanner.py hooks/shared/audit_logger.py hooks/shared/policy_loader.py policies/secret-patterns.yml"
    SEC_DECISION="trusted"
    # T32 (RELIABILITY #3, MSYS): the sentinel `git ls-tree HEAD` is captured via a FILE
    # REDIRECT, NOT `$(git ls-tree ...)` command substitution. On MSYS/Git-Bash a
    # Windows-native git grandchild can hold the captured pipe open past exit, hanging the
    # parent shell (rc=124) — the documented $(...)+git freeze that was the source of the
    # gate timeouts. This is fail-SAFE (a hung hook only ever BLOCKS), not a security
    # change; the trusted-vs-fallback semantics are IDENTICAL (rc!=0 => fail closed; rc0+
    # empty => first-adoption fallback). Uses the same file-redirect pattern the PREP
    # extractor already relies on. The scratch file lives in SEC_LSFILE.
    SEC_LSFILE="$(mktemp 2>/dev/null || mktemp -t ffflow-secls)"
    if ! git rev-parse --verify --quiet HEAD >/dev/null 2>&1; then
        SEC_DECISION="fallback"
        echo "[fusebase-flow:pre-commit] note: no HEAD yet (first-adoption bootstrap) — §2 secret scan uses the working-tree scanner for this initial commit." >&2
    else
        for _s in $SEC_SENTINELS; do
            git ls-tree HEAD -- "$_s" > "$SEC_LSFILE" 2>/dev/null; _sls_rc=$?
            _sls="$(cat "$SEC_LSFILE" 2>/dev/null)"
            if [ "$_sls_rc" -ne 0 ]; then
                rm -f "$SEC_LSFILE"
                echo "[fusebase-flow:pre-commit] BLOCK — §2 secret scan could not read the trusted HEAD copy of $_s (transient git error, rc=$_sls_rc) — failing closed, NOT falling back to the untrusted working tree. NEVER use --no-verify." >&2
                exit 1
            fi
            if [ -z "$_sls" ]; then
                SEC_DECISION="fallback"
                echo "[fusebase-flow:pre-commit] note: $_s not in HEAD (first-adoption bootstrap) — §2 secret scan uses the working-tree scanner for this commit." >&2
                break
            fi
        done
    fi
    rm -f "$SEC_LSFILE"
    # T32 (primary CWD-strip fix): create the scratch/trusted temp dir UNCONDITIONALLY. The
    # §2 MAIN check now runs as a FILE SCRIPT from this dir (python3 -S "$SEC_TMP/_main_secret.py"),
    # so sys.path[0] is the trusted temp dir — NOT the repo-root CWD, which `-S -` (stdin) would
    # otherwise leave on sys.path[0] and let a repo-root pathlib.py/yaml.py shadow win before any
    # scrub. On the TRUSTED path the extractor also fills shared/+policies/ here; on the FALLBACK
    # path the dir holds ONLY the wrapper (SEC_IMPORT_DIR stays $ROOT/hooks, inserted by the wrapper).
    SEC_TMP="$(mktemp -d 2>/dev/null || mktemp -d -t ffflow-secret)"
    if [ "$SEC_DECISION" = "trusted" ]; then
        # Pure extractor (git show HEAD -> temp; no verdict). Written to a file, not a
        # heredoc-in-$(...) (bash -n here-doc parse). Fail closed on any git-show failure.
        cat > "$SEC_TMP/_prep_secret.py" <<'SECPREP'
import os, subprocess, sys
from pathlib import Path

root = Path(os.environ["ROOT"])
tmp = Path(os.environ["SEC_TMP"])

# The SHELL has already proven (git ls-tree) every one of these is present in HEAD; this
# script only EXTRACTS the trusted bytes. secret-patterns.local.yml is an OPTIONAL,
# gitignored designed-token override (never in HEAD) — deliberately NOT extracted; the
# trusted-patterns seed below binds the loader to ONLY HEAD's committed patterns.
files = [
    ("hooks/shared/__init__.py",            tmp / "shared" / "__init__.py"),
    ("hooks/shared/staged_secret_scan.py",  tmp / "shared" / "staged_secret_scan.py"),
    ("hooks/shared/secret_scanner.py",      tmp / "shared" / "secret_scanner.py"),
    ("hooks/shared/audit_logger.py",        tmp / "shared" / "audit_logger.py"),
    ("hooks/shared/policy_loader.py",       tmp / "shared" / "policy_loader.py"),
    ("policies/secret-patterns.yml",        tmp / "policies" / "secret-patterns.yml"),
]

for src, dst in files:
    dst.parent.mkdir(parents=True, exist_ok=True)
    show = subprocess.run(["git", "show", f"HEAD:{src}"],
                          capture_output=True, cwd=str(root))
    if show.returncode != 0:
        print(f"[fusebase-flow:pre-commit] BLOCK — §2 trusted HEAD extraction of {src} "
              f"failed (git show rc={show.returncode}) — failing closed. NEVER use --no-verify.",
              file=sys.stderr)
        sys.exit(1)
    dst.write_bytes(show.stdout)
SECPREP
        SEC_TMP="$SEC_TMP" ROOT="$ROOT" PYTHONPATH="" python3 -S "$SEC_TMP/_prep_secret.py"; SEC_PREP_RC=$?
        if [ "$SEC_PREP_RC" -ne 0 ]; then
            [ -n "$SEC_TMP" ] && rm -rf "$SEC_TMP"
            exit 1
        fi
        SEC_IMPORT_DIR="$SEC_TMP"
        SEC_TRUSTED_PATTERNS="$SEC_TMP/policies/secret-patterns.yml"
    fi
    # `-S` (T29): no working-tree/untracked sitecustomize.py/usercustomize.py at startup.
    # PYTHONPATH is set EXPLICITLY to the SINGLE import dir (T30 scrubbed the env at the top,
    # so nothing is inherited) — the trusted temp dir on the normal path, $ROOT/hooks ONLY on
    # the first-adoption bootstrap fallback. The scanner re-adds site-packages (for PyYAML)
    # via getsitepackages() PATHS without running site.main() (its own _restore_site_packages).
    #
    # T32 (PRIMARY CWD-strip fix): the MAIN check runs as a FILE SCRIPT from the trusted temp
    # dir (python3 -S "$SEC_TMP/_main_secret.py"), NOT `python3 -S -` (stdin). For a file script
    # sys.path[0] is the SCRIPT'S dir (the trusted temp dir) and the CWD is never added — so a
    # repo-root pathlib.py/yaml.py can no longer shadow stdlib/site before the scrub or the
    # trusted-patterns seed's `import yaml`. (Stdin `-` used to put the repo-root CWD at
    # sys.path[0]; `-S` disables site but does NOT remove the CWD.) The wrapper ALSO scrubs any
    # residual CWD/'' entry as its first statements (belt-and-suspenders, unshadowable builtin
    # os core) so the guarantee holds even on interpreters that ignore PYTHONSAFEPATH.
    cat > "$SEC_TMP/_main_secret.py" <<'SECPY'
import sys
# T32 CWD-STRIP (first statements, before ANY non-builtin import): remove the repo-root/CWD/''
# entries a stdin/`-c` invocation would leave on sys.path. Get CWD via a BUILTIN os core
# (`nt` on Windows / `posix` on POSIX — both in sys.builtin_module_names, so a repo-root
# nt.py/posix.py cannot shadow them). sys itself is builtin (unshadowable). Idempotent: a
# no-op when the file-script/PYTHONSAFEPATH path already stripped CWD. NOT `del sys.path[0]`
# (that would wrongly drop the stdlib entry when CWD was already absent).
_cwd = None
try:
    import nt as _oscore  # Windows
except ImportError:
    import posix as _oscore  # POSIX
try:
    _cwd = _oscore.getcwd()
except Exception:
    _cwd = None
_drop = {"", "."}
if _cwd:
    _drop.add(_cwd)
sys.path[:] = [p for p in sys.path if p not in _drop]
import os
from pathlib import Path
# root = the REAL repo: the STAGED diff (git diff --cached) + working-tree cwd are read
# from here, regardless of whether the scanner CODE was imported from HEAD (trusted) or
# the tree (bootstrap fallback).
root = Path(os.environ["SEC_REAL_ROOT"])
import_dir = os.environ.get("SEC_IMPORT_DIR") or str(root / "hooks")
sys.path.insert(0, import_dir)
try:
    # staged_secret_scan imports only stdlib at module top (subprocess/sys/pathlib), so
    # importing it does NOT yet reach policy_loader's top-level `import yaml`. Restore
    # site-packages FIRST (via its own -S-safe getsitepackages re-add), THEN import
    # secret_scanner — whose transitive `import yaml` would SystemExit under bare `-S` if
    # site-packages were still dropped (the ordering the original helper's main() used).
    from shared.staged_secret_scan import staged_added_text, _restore_site_packages
    _restore_site_packages()
    from shared.secret_scanner import block_decision, scan
except BaseException as e:
    # FAIL CLOSED (mirrors §3's BaseException guard): a tampered/short-circuited scanner
    # module doing raise SystemExit(0) on import subclasses BaseException; blocking it here
    # means a broken/lying scanner cannot wave a secret through. (A genuinely scanner-less
    # bootstrap took the shell fallback above, not this trusted path.)
    print(f"[fusebase-flow:pre-commit] BLOCK — §2 secret scan could not load the scanner (import error: {e!r}) — failing closed. NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
# TRUSTED-PATTERNS SEED (mirrors §3's trusted-policy seed): scan() -> get_policy(
# "secret-patterns") would otherwise read the mutable working-tree patterns file (which a
# tamperer could have emptied). Seed the loader cache with the TRUSTED HEAD patterns under
# BOTH keys the scanner reaches (root=None internal call + the cwd-derived root), so every
# get_policy("secret-patterns") returns the trusted patterns. Scoped to secret-patterns
# ONLY (other policies untouched). On the bootstrap fallback SEC_TRUSTED_PATTERNS is empty
# => no seed => the scanner reads the working-tree patterns (a scanner-less repo can't tamper
# a control it doesn't yet have).
trusted_patterns = os.environ.get("SEC_TRUSTED_PATTERNS") or ""
if trusted_patterns:
    try:
        import yaml
        from shared import policy_loader as _pl
        pol = yaml.safe_load(Path(trusted_patterns).read_text(encoding="utf-8")) or {}
        _pl._POLICY_CACHE["::secret-patterns"] = pol
        _pl._POLICY_CACHE[f"{root}::secret-patterns"] = pol
    except BaseException as e:
        print(f"[fusebase-flow:pre-commit] BLOCK — §2 secret scan could not seed the trusted HEAD patterns ({e!r}) — failing closed. NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
# Scan the STAGED changeset (added `+` lines, designed-token files path-excluded — the
# exclude lives in staged_added_text, run against the REAL root's git). block => exit 1.
try:
    matches = scan(staged_added_text(root), tool_context="git_pre_commit")
except BaseException as e:
    print(f"[fusebase-flow:pre-commit] BLOCK — §2 secret scan errored ({e!r}) — failing closed. NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
if matches and block_decision(matches) == "deny":
    print("[fusebase-flow:pre-commit] BLOCK — secret pattern in staged added lines:", file=sys.stderr)
    for m in matches:
        print(f"  {m.pattern_id} ({m.confidence}) — redacted", file=sys.stderr)
    print("Per FR-12: rotate the credential, then `git reset HEAD -- <file>` to unstage. Do NOT whitelist the value to get past this.", file=sys.stderr)
    sys.exit(1)
SECPY
    # Run the MAIN §2 check as a FILE SCRIPT (T32): sys.path[0] = the trusted temp dir, not the
    # repo-root CWD. PYTHONPATH is still the SINGLE trusted import dir (T30 scrubbed the env).
    SEC_IMPORT_DIR="$SEC_IMPORT_DIR" SEC_TRUSTED_PATTERNS="$SEC_TRUSTED_PATTERNS" \
    SEC_REAL_ROOT="$ROOT" PYTHONPATH="$SEC_IMPORT_DIR" python3 -S "$SEC_TMP/_main_secret.py" || exit_secret=$?
    # Clean up the trusted temp package (FR-27 no-runaways: bounded, always removed)
    # BEFORE acting on the rc so a BLOCK never leaks the temp dir.
    [ -n "$SEC_TMP" ] && rm -rf "$SEC_TMP"
    if [ "${exit_secret:-0}" -ne 0 ]; then exit 1; fi
fi

# 3. Reject protected-path edits without an active exception artifact. Covers the
#    FULL staged change set — ADDS/MODS *and* DELETES + RENAMES (a `git rm` or rename
#    of a protected file must reach path_policy too; the old ACM-only set let deletes/
#    rename-sources through with exit 0 — the shipped FR-07 bypass). The gate fires on
#    ANY staged change (unfiltered), not just ACM. §1/§2 secret checks stay ACM by
#    design (deleting a file can't leak a secret).
#    This is a SECURITY control: it FAILS CLOSED. An import error (missing dep, broken/
#    tampered path_policy, a syntax error introduced in the SAME commit) or any unexpected
#    error inside the check EXITS 1 (block) — never exit 0. A silent fail-open would let a
#    protected edit through the moment path_policy can't load. python3 absent + staged
#    changes => a LOUD warn (not a hard block: a python3-less env must still be able to
#    commit, and §2 already gates on python3), so the un-enforceable gap is never silent.
# #1 (T27): capture the OUTER git-list rc too (mirrors the inner python rc-check). A
# nonzero rc here means we can't reliably know whether protected paths are staged, so
# fail closed rather than skip §3 on an empty-because-broken list. (Non-reachable in a
# healthy repo — a broken repo won't commit — but cheap and consistent.)
#
# TRUSTED-HEAD ENFORCER (T28→T29, UNCONDITIONAL): the enforcement code (path_policy.py /
# policy_loader.py / shared/__init__.py) and the protected-paths.yml policy are THEMSELVES
# fusebase_flow_internals — the mutable working tree cannot be trusted to enforce its own
# protection. §3 therefore runs the enforcer from the COMMITTED (HEAD) copy of that code +
# policy for EVERY commit with staged changes, not just when the STAGED set touches those
# files. T28 made it conditional (fired only when the enforcer files were staged); that left
# two reachable bypasses the clean-HEAD run now closes:
#   (a) UNSTAGED enforcer tamper: edit the working-tree path_policy.py to lie ("nothing
#       protected") WITHOUT staging it, then stage only a protected file — the conditional
#       stayed off, §3 imported the lying working-tree enforcer, exit 0. Now HEAD's clean
#       enforcer always runs, so the unstaged lie has no effect.
#   (b) Python STARTUP injection: an untracked hooks/sitecustomize.py (or usercustomize.py)
#       with `import os; os._exit(0)` is imported at interpreter startup via `site` BEFORE any
#       check — the check exited 0. Closed by invoking EVERY §3 python (PREP + MAIN, T30) with
#       `-S` (site disabled ⇒ no sitecustomize/usercustomize), the hook env pre-scrubbed
#       (unset PYTHONPATH/STARTUP/HOME at the top), and PYTHONPATH set to ONLY the trusted temp
#       dir (never $ROOT/hooks), so no working-tree startup file is importable.
#   (c) [T30] PREP-STEP injection + python-writable verdict: T29's PREP (git-show extraction)
#       still ran PLAIN python3 with INHERITED PYTHONPATH, and the trusted-vs-fallback verdict
#       was a `RESULT=...` value a python startup file could WRITE. Live PoC:
#       `PYTHONPATH=$ROOT/hooks` + untracked hooks/sitecustomize.py forging `RESULT=fallback` /
#       os._exit(0) + an unstaged lying path_policy.py + a staged protected file => exit 0.
#       Closed by: (1) the env scrub above; (2) `-S` + a controlled PYTHONPATH on the PREP
#       invocation; and (3) moving the trusted-vs-fallback DECISION out of python entirely —
#       the SHELL decides it via `git ls-tree HEAD` on the sentinel enforcer files (below),
#       an unforgeable signal no python/startup file can write. If git proves HEAD HAS the
#       enforcer => ALWAYS trusted (fallback is IMPOSSIBLE — a forged RESULT cannot be honored);
#       fall back to the working tree ONLY when git proves HEAD genuinely LACKS it. The PREP
#       python is now a pure EXTRACTOR (git show HEAD -> temp); it no longer votes.
# The CLEAN enforcer evaluates the STAGED changeset, still sees `hooks/shared/**` +
# `policies/protected-paths.yml` as protected, reads the WORKING-TREE state/approvals/ (so a
# legit sanctioned edit still passes) + STAGED git (the real commit), and BLOCKS an unapproved
# protected edit. For a clean tree HEAD==working-tree, so behavior is IDENTICAL to before.
# BOOTSTRAP edge: on the first commit that ADDS these files, HEAD lacks them -> the shell
# `git ls-tree HEAD` reports rc0+empty (genuinely absent) -> fall back to the working-tree
# enforcer (the file being added is not a tamper), still under `-S`. A TRANSIENT git error
# (HEAD has the file but the read fails) is NOT bootstrap -> fail closed (never fall back to
# the untrusted tree on an unexplained error; T26/T27 contract).
# ACCEPTED RESIDUALS (a commit-time discipline guardrail cannot mechanically stop these — they
# are rule-forbidden and/or out of band): `--no-verify` (FR rule-forbidden), deleting/replacing
# `.git/hooks/pre-commit` on disk, and a full repo write that never invokes this hook. Documented
# in the deploy problem-catalog; enforcement of those relies on FR discipline + review, not §3.
STAGED_ANY="$(git diff --cached --name-only 2>/dev/null)"; STAGED_ANY_RC=$?
if [ "$STAGED_ANY_RC" -ne 0 ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — FR-07 could not list staged changes (outer git rc=$STAGED_ANY_RC) — failing closed." >&2
    echo "Refusing to commit fail-open on an unverifiable protected-path check; NEVER use --no-verify." >&2
    exit 1
fi
if [ -n "$STAGED_ANY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        # UNCONDITIONAL trusted-HEAD (T29): the working-tree enforcer is never trusted to
        # enforce its own protection, so §3 ALWAYS runs from the COMMITTED (HEAD) enforcer +
        # policy — not just when the staged set touches those files (T28's conditional left
        # the unstaged-tamper + startup-injection bypasses reachable). Extract HEAD's copies
        # into a temp dir; import/run FR-07 from THERE with `-S` + an isolated PYTHONPATH.
        # FR07_IMPORT_DIR = where the enforcement `shared` package is imported from;
        # FR07_TRUSTED_POLICY = the trusted policy yaml to seed (empty => bootstrap fallback).
        # Defaults are the working-tree path — used ONLY on the first-adoption bootstrap edge
        # (HEAD genuinely lacks the enforcer); otherwise the trusted temp dir replaces them.
        FR07_IMPORT_DIR="$ROOT/hooks"
        FR07_TRUSTED_POLICY=""
        FR07_TMP=""
        # GIT-BASED TRUSTED-vs-FALLBACK DECISION (T30, unforgeable). The SHELL — not any
        # python script or startup file — decides whether HEAD carries the enforcer. `git
        # ls-tree HEAD -- <sentinel>` is run directly by bash, so no PYTHONPATH/sitecustomize
        # can influence it. Three outcomes per sentinel:
        #   rc0 + non-empty stdout => present in HEAD;
        #   rc0 + empty stdout      => genuinely absent (first-adoption bootstrap);
        #   rc!=0                    => transient git error -> fail closed (no fallback).
        # RULE: if ALL sentinels are present in HEAD => TRUSTED (a forged RESULT=fallback is
        # impossible to honor — there is no python-written verdict any more). Fall back to the
        # working-tree enforcer ONLY when git proves a sentinel is genuinely absent (true
        # first-adoption). The PREP python below is then a pure EXTRACTOR (git show -> temp);
        # it no longer votes on trusted-vs-fallback.
        FR07_SENTINELS="hooks/shared/__init__.py hooks/shared/path_policy.py hooks/shared/policy_loader.py policies/protected-paths.yml"
        FR07_DECISION="trusted"
        # T32 (RELIABILITY #3, MSYS): capture the sentinel `git ls-tree HEAD` via a FILE
        # REDIRECT, NOT `$(git ls-tree ...)` command substitution — the $(...)+git pattern
        # intermittently HANGS under MSYS/Git-Bash (a Windows-native git grandchild holds the
        # captured pipe open past exit => rc=124), the source of the gate timeouts. Fail-SAFE
        # (a hung hook only ever BLOCKS); the trusted-vs-fallback semantics are IDENTICAL
        # (rc!=0 => fail closed; rc0+empty => first-adoption fallback). Same file-redirect
        # pattern the PREP extractor already uses. Scratch file in FR07_LSFILE.
        FR07_LSFILE="$(mktemp 2>/dev/null || mktemp -t ffflow-fr07ls)"
        # Unborn HEAD (no commits yet) is a legitimate first-adoption bootstrap, not transient.
        if ! git rev-parse --verify --quiet HEAD >/dev/null 2>&1; then
            FR07_DECISION="fallback"
