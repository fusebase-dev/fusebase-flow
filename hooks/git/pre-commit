#!/usr/bin/env bash
# Fusebase Flow — pre-commit git hook
# fusebase-flow-managed-hook: v1
#
# Runs before each commit. Defends FR-07 (worker-undisturbed), FR-12 (secrets),
# FR-13 (lint+typecheck), and FR-25 (module-size ratchet). Original Fusebase
# Flow content; clean-room.
#
# Install: bash hooks/local/install-git-hooks.sh
#
# Bypass: NEVER use --no-verify. Real secret flagged => rotate + `git reset HEAD --
# <file>` to unstage; never whitelist it (disables a pattern globally, breaks the
# scanner's own fixtures 10/11). False positive => fix the pattern.
# Known scan-scope limits (docs/compatibility.md § Secret-scan): designed-token
# files are path-excluded; PreToolUse self-trips when an agent writes full
# secret-patterns.yml content.

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
    echo "[fusebase-flow:pre-commit] not in a git repo; skipping" >&2
    exit 0
fi

cd "$ROOT" || exit 0

# 1. Reject likely secret files in staged changes.
SECRETS_REGEX='\.env$|\.env\.[^\.]*$|credentials\.json$|/secrets/|\.pem$|\.key$|\.netrc$'
STAGED_PATHS="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"
SECRET_HITS="$(echo "$STAGED_PATHS" | grep -E "$SECRETS_REGEX" || true)"
if [ -n "$SECRET_HITS" ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — secret-like files staged:" >&2
    echo "$SECRET_HITS" | sed 's/^/  /' >&2
    echo "Per FR-12: never commit secrets. Unstage with \`git reset HEAD -- <file>\` and rotate if leaked." >&2
    exit 1
fi

# 2. Secret content scan: ONLY added (+) lines, designed-token files path-excluded
#    (D-A1 — secret-patterns.yml self-trip + whitelist trap). Helper, not inline
#    bash string-parsing: hooks/shared/staged_secret_scan.py. scan() is UNCHANGED.
if command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$ROOT/hooks" python3 "$ROOT/hooks/shared/staged_secret_scan.py" || exit_secret=$?
    if [ "${exit_secret:-0}" -ne 0 ]; then exit 1; fi
fi

# 3. Reject protected-path edits without an active exception artifact. Covers the
#    FULL staged change set — ADDS/MODS *and* DELETES + RENAMES (a `git rm` or rename
#    of a protected file must reach path_policy too; the old ACM-only set let deletes/
#    rename-sources through with exit 0 — the shipped FR-07 bypass). The gate fires on
#    ANY staged change (unfiltered), not just ACM. §1/§2 secret checks stay ACM by
#    design (deleting a file can't leak a secret).
STAGED_ANY="$(git diff --cached --name-only 2>/dev/null || true)"
if [ -n "$STAGED_ANY" ] && command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$ROOT/hooks" python3 - <<'PY' || exit_proto=$?
import sys
from pathlib import Path
root = Path.cwd()
sys.path.insert(0, str(root / "hooks"))
try:
    from shared.path_policy import evaluate, staged_change_paths
except Exception:
    sys.exit(0)
paths = staged_change_paths(root)
hits = []
for p in paths:
    pd = evaluate(p)
    if pd.protected and not pd.has_exception:
        hits.append(pd)
if hits:
    print("[fusebase-flow:pre-commit] BLOCK — protected paths edited without exception artifact:", file=sys.stderr)
    for h in hits:
        print(f"  {h.path}  (category={h.category})", file=sys.stderr)
    print("Per FR-07: author an approval artifact at state/approvals/ first.", file=sys.stderr)
    sys.exit(1)
PY
    if [ "${exit_proto:-0}" -ne 0 ]; then exit 1; fi
fi

# 4. Module-size ratchet (FR-25). Warn-only until policies/module-size-baseline.txt
#    is committed; then over-ceiling growth blocks (extract or operator exemption).
if [ -f "$ROOT/hooks/local/check-module-size.sh" ]; then
    if ! bash "$ROOT/hooks/local/check-module-size.sh" --staged; then
        echo "[fusebase-flow:pre-commit] BLOCK — module-size ratchet failed (FR-25)." >&2
        exit 1
    fi
fi

# 5. Lint + typecheck (FR-13). Project hooks may set FUSEBASE_FLOW_LINT / FUSEBASE_FLOW_TYPECHECK.
LINT_CMD="${FUSEBASE_FLOW_LINT:-}"
TYPECHECK_CMD="${FUSEBASE_FLOW_TYPECHECK:-}"

# Auto-detect node project lint/typecheck if env vars are unset.
if [ -z "$LINT_CMD" ] && [ -f package.json ] && grep -q '"lint"' package.json; then
    LINT_CMD="npm run -s lint"
fi
if [ -z "$TYPECHECK_CMD" ] && [ -f package.json ] && grep -q '"typecheck"' package.json; then
    TYPECHECK_CMD="npm run -s typecheck"
fi

if [ -n "$LINT_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running lint: $LINT_CMD" >&2
    if ! eval "$LINT_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — lint failed (FR-13)." >&2
        exit 1
    fi
fi

if [ -n "$TYPECHECK_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running typecheck: $TYPECHECK_CMD" >&2
    if ! eval "$TYPECHECK_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — typecheck failed (FR-13)." >&2
        exit 1
    fi
fi

echo "[fusebase-flow:pre-commit] all checks passed" >&2
exit 0
