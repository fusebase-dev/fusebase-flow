#!/usr/bin/env bash
# Fusebase Flow — pre-commit git hook
# fusebase-flow-managed-hook: v1
#
# Runs before each commit. Defends FR-07 (worker-undisturbed), FR-12 (secrets),
# FR-13 (lint+typecheck), and FR-25 (module-size ratchet). Original Fusebase
# Flow content; clean-room.
#
# Install: bash hooks/local/install-git-hooks.sh
#
# Bypass: NEVER use --no-verify. Real secret flagged => rotate + `git reset HEAD --
# <file>` to unstage; never whitelist it (disables a pattern globally, breaks the
# scanner's own fixtures 10/11). False positive => fix the pattern.
# Known scan-scope limits (docs/compatibility.md § Secret-scan): designed-token
# files are path-excluded; PreToolUse self-trips when an agent writes full
# secret-patterns.yml content.

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
    echo "[fusebase-flow:pre-commit] not in a git repo; skipping" >&2
    exit 0
fi

cd "$ROOT" || exit 0

# 1. Reject likely secret files in staged changes.
SECRETS_REGEX='\.env$|\.env\.[^\.]*$|credentials\.json$|/secrets/|\.pem$|\.key$|\.netrc$'
STAGED_PATHS="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"
SECRET_HITS="$(echo "$STAGED_PATHS" | grep -E "$SECRETS_REGEX" || true)"
if [ -n "$SECRET_HITS" ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — secret-like files staged:" >&2
    echo "$SECRET_HITS" | sed 's/^/  /' >&2
    echo "Per FR-12: never commit secrets. Unstage with \`git reset HEAD -- <file>\` and rotate if leaked." >&2
    exit 1
fi

# 2. Secret content scan: ONLY added (+) lines, designed-token files path-excluded
#    (D-A1 — secret-patterns.yml self-trip + whitelist trap). Helper, not inline
#    bash string-parsing: hooks/shared/staged_secret_scan.py. scan() is UNCHANGED.
#    `-S` (T29): a working-tree/untracked sitecustomize.py doing `os._exit(0)` at
#    interpreter startup would ALSO disable this scan; `-S` skips site startup files.
#    The helper restores site-packages (for PyYAML) itself without re-importing them.
if command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$ROOT/hooks" python3 -S "$ROOT/hooks/shared/staged_secret_scan.py" || exit_secret=$?
    if [ "${exit_secret:-0}" -ne 0 ]; then exit 1; fi
fi

# 3. Reject protected-path edits without an active exception artifact. Covers the
#    FULL staged change set — ADDS/MODS *and* DELETES + RENAMES (a `git rm` or rename
#    of a protected file must reach path_policy too; the old ACM-only set let deletes/
#    rename-sources through with exit 0 — the shipped FR-07 bypass). The gate fires on
#    ANY staged change (unfiltered), not just ACM. §1/§2 secret checks stay ACM by
#    design (deleting a file can't leak a secret).
#    This is a SECURITY control: it FAILS CLOSED. An import error (missing dep, broken/
#    tampered path_policy, a syntax error introduced in the SAME commit) or any unexpected
#    error inside the check EXITS 1 (block) — never exit 0. A silent fail-open would let a
#    protected edit through the moment path_policy can't load. python3 absent + staged
#    changes => a LOUD warn (not a hard block: a python3-less env must still be able to
#    commit, and §2 already gates on python3), so the un-enforceable gap is never silent.
# #1 (T27): capture the OUTER git-list rc too (mirrors the inner python rc-check). A
# nonzero rc here means we can't reliably know whether protected paths are staged, so
# fail closed rather than skip §3 on an empty-because-broken list. (Non-reachable in a
# healthy repo — a broken repo won't commit — but cheap and consistent.)
#
# TRUSTED-HEAD ENFORCER (T28→T29, UNCONDITIONAL): the enforcement code (path_policy.py /
# policy_loader.py / shared/__init__.py) and the protected-paths.yml policy are THEMSELVES
# fusebase_flow_internals — the mutable working tree cannot be trusted to enforce its own
# protection. §3 therefore runs the enforcer from the COMMITTED (HEAD) copy of that code +
# policy for EVERY commit with staged changes, not just when the STAGED set touches those
# files. T28 made it conditional (fired only when the enforcer files were staged); that left
# two reachable bypasses the clean-HEAD run now closes:
#   (a) UNSTAGED enforcer tamper: edit the working-tree path_policy.py to lie ("nothing
#       protected") WITHOUT staging it, then stage only a protected file — the conditional
#       stayed off, §3 imported the lying working-tree enforcer, exit 0. Now HEAD's clean
#       enforcer always runs, so the unstaged lie has no effect.
#   (b) Python STARTUP injection: an untracked hooks/sitecustomize.py (or usercustomize.py)
#       with `import os; os._exit(0)` is imported at interpreter startup via `site` BEFORE any
#       check — the check exited 0. Closed by invoking the §3 (and §2) python with `-S`
#       (site disabled ⇒ no sitecustomize/usercustomize) AND setting PYTHONPATH to ONLY the
#       trusted temp dir (never $ROOT/hooks), so no working-tree startup file is importable.
# The CLEAN enforcer evaluates the STAGED changeset, still sees `hooks/shared/**` +
# `policies/protected-paths.yml` as protected, reads the WORKING-TREE state/approvals/ (so a
# legit sanctioned edit still passes) + STAGED git (the real commit), and BLOCKS an unapproved
# protected edit. For a clean tree HEAD==working-tree, so behavior is IDENTICAL to before.
# BOOTSTRAP edge: on the first commit that ADDS these files, HEAD lacks them -> `git ls-tree`
# reports rc0+empty (genuinely absent) -> fall back to the working-tree enforcer (the file being
# added is not a tamper), still under `-S`. A TRANSIENT git error (HEAD has the file but the
# read fails) is NOT bootstrap -> fail closed (never fall back to the untrusted tree on an
# unexplained error; T26/T27 contract).
# ACCEPTED RESIDUALS (a commit-time discipline guardrail cannot mechanically stop these — they
# are rule-forbidden and/or out of band): `--no-verify` (FR rule-forbidden), deleting/replacing
# `.git/hooks/pre-commit` on disk, and a full repo write that never invokes this hook. Documented
# in the deploy problem-catalog; enforcement of those relies on FR discipline + review, not §3.
STAGED_ANY="$(git diff --cached --name-only 2>/dev/null)"; STAGED_ANY_RC=$?
if [ "$STAGED_ANY_RC" -ne 0 ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — FR-07 could not list staged changes (outer git rc=$STAGED_ANY_RC) — failing closed." >&2
    echo "Refusing to commit fail-open on an unverifiable protected-path check; NEVER use --no-verify." >&2
    exit 1
fi
if [ -n "$STAGED_ANY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        # UNCONDITIONAL trusted-HEAD (T29): the working-tree enforcer is never trusted to
        # enforce its own protection, so §3 ALWAYS runs from the COMMITTED (HEAD) enforcer +
        # policy — not just when the staged set touches those files (T28's conditional left
        # the unstaged-tamper + startup-injection bypasses reachable). Extract HEAD's copies
        # into a temp dir; import/run FR-07 from THERE with `-S` + an isolated PYTHONPATH.
        # FR07_IMPORT_DIR = where the enforcement `shared` package is imported from;
        # FR07_TRUSTED_POLICY = the trusted policy yaml to seed (empty => bootstrap fallback).
        # Defaults are the working-tree path — used ONLY on the first-adoption bootstrap edge
        # (HEAD genuinely lacks the enforcer); otherwise the trusted temp dir replaces them.
        FR07_IMPORT_DIR="$ROOT/hooks"
        FR07_TRUSTED_POLICY=""
        FR07_TMP=""
        # Trusted-HEAD extraction runs for EVERY staged commit now (T29 — no conditional).
        # The block below is kept in a `{ ... }` group only to scope the temp-dir prep; the
        # verdict (trusted vs bootstrap-fallback) is decided by the prep script, never skipped.
        {
            FR07_TMP="$(mktemp -d 2>/dev/null || mktemp -d -t ffflow-trusted)"
            # Write the prep script to a file (NOT a heredoc inside $(...), which some bash
            # -n parsers flag as an unterminated here-doc) then run it. It writes its verdict
            # (`RESULT=trusted|fallback`) to $FR07_TMP/_result (read as a FILE below, never
            # via $(...)); notes/diagnostics go to stderr (pass through to the operator);
            # exits 1 on a TRANSIENT git error (fail closed, no fall-back to the untrusted tree).
            cat > "$FR07_TMP/_prep.py" <<'PREP'
import os, subprocess, sys
from pathlib import Path

root = Path(os.environ["ROOT"])
tmp = Path(os.environ["FR07_TMP"])

def _result(root, tmp):
    return tmp / "_result"

# (repo-relative source path, destination inside the temp trusted package)
files = [
    ("hooks/shared/__init__.py",       tmp / "shared" / "__init__.py"),
    ("hooks/shared/path_policy.py",    tmp / "shared" / "path_policy.py"),
    ("hooks/shared/policy_loader.py",  tmp / "shared" / "policy_loader.py"),
    ("policies/protected-paths.yml",   tmp / "policies" / "protected-paths.yml"),
]

def head_has(path: str):
    """(exists, transient_error). Uses `git ls-tree HEAD -- <path>`, which cleanly
    separates the three cases where `git cat-file -e` does not:
      rc0 + non-empty stdout => the path IS in the HEAD tree (present);
      rc0 + EMPTY stdout      => the path is genuinely ABSENT in HEAD (first-adoption
                                 bootstrap — a valid `git ls-tree` that lists nothing);
      rc!=0 / exception       => git itself failed (transient / unresolvable) -> fail closed.
    (`git cat-file -e HEAD:<path>` returns rc 128 for BOTH "path not in tree" and repo
    errors — indistinguishable — so it cannot drive the bootstrap-vs-transient split.)"""
    try:
        r = subprocess.run(["git", "ls-tree", "HEAD", "--", path],
                           capture_output=True, text=True, cwd=str(root))
    except Exception:
        return False, True
    if r.returncode != 0:
        return False, True       # git failed -> transient / unresolvable
    if r.stdout.strip():
        return True, False       # path present in HEAD
    return False, False          # rc0 + empty -> genuinely absent in HEAD (bootstrap)

# Unborn HEAD (no commits yet) is a legitimate first-adoption bootstrap, not transient.
head_ref = subprocess.run(["git", "rev-parse", "--verify", "--quiet", "HEAD"],
                          capture_output=True, text=True, cwd=str(root))
if head_ref.returncode != 0:
    _result(root, tmp).write_text("RESULT=fallback\n", encoding="utf-8")
    print("[fusebase-flow:pre-commit] note: no HEAD yet (first-adoption bootstrap) — "
          "FR-07 §3 uses the working-tree enforcer for this initial commit.", file=sys.stderr)
    sys.exit(0)

for src, _dst in files:
    exists, transient = head_has(src)
    if transient:
        print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 could not read the trusted HEAD "
              f"copy of {src} (transient git error) — failing closed, NOT falling back to "
              f"the untrusted working tree. NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
    if not exists:
        # A required trusted file is absent in HEAD => this commit is ADDING the enforcer
        # (first-adoption). The added file is not a tamper of an existing control; fall back
        # to the working-tree enforcer (which is all that exists) with a one-line note.
        _result(root, tmp).write_text("RESULT=fallback\n", encoding="utf-8")
        print(f"[fusebase-flow:pre-commit] note: {src} not in HEAD (first-adoption "
              f"bootstrap) — FR-07 §3 uses the working-tree enforcer for this commit.",
              file=sys.stderr)
        sys.exit(0)

# All present in HEAD => extract the TRUSTED copies into the temp package.
for src, dst in files:
    dst.parent.mkdir(parents=True, exist_ok=True)
    show = subprocess.run(["git", "show", f"HEAD:{src}"],
                          capture_output=True, cwd=str(root))
    if show.returncode != 0:
        # ls-tree said it exists but show failed => TRANSIENT/unexpected => fail closed.
        print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 trusted HEAD extraction of {src} "
              f"failed (git show rc={show.returncode}) — failing closed. NEVER use --no-verify.",
              file=sys.stderr)
        sys.exit(1)
    dst.write_bytes(show.stdout)
_result(root, tmp).write_text("RESULT=trusted\n", encoding="utf-8")
PREP
            # Invoke prep WITHOUT $(...) command substitution: on MSYS a Windows-native git
            # grandchild can hold a captured pipe open past exit and hang the parent (the
            # documented $(...) freeze). The prep writes its verdict to $FR07_TMP/_result and
            # we read the FILE; stdout/stderr flow straight to the terminal (notes visible).
            FR07_TMP="$FR07_TMP" ROOT="$ROOT" python3 "$FR07_TMP/_prep.py"; PREP_RC=$?
            if [ "$PREP_RC" -ne 0 ]; then
                # Transient extraction error => fail closed (diagnostic already on stderr).
                [ -n "$FR07_TMP" ] && rm -rf "$FR07_TMP"
                exit 1
            fi
            PREP_OUT="$(cat "$FR07_TMP/_result" 2>/dev/null || true)"
            case "$PREP_OUT" in
                *RESULT=trusted*)
                    FR07_IMPORT_DIR="$FR07_TMP"
                    FR07_TRUSTED_POLICY="$FR07_TMP/policies/protected-paths.yml"
                    ;;
                *RESULT=fallback*)
                    # Bootstrap first-add: keep the working-tree defaults (import dir + no seed).
                    ;;
                *)
                    # Unexpected prep output with rc0 — treat as unverifiable => fail closed.
                    echo "[fusebase-flow:pre-commit] BLOCK — FR-07 trusted-HEAD preparation returned an unexpected result — failing closed. NEVER use --no-verify." >&2
                    [ -n "$FR07_TMP" ] && rm -rf "$FR07_TMP"
                    exit 1
                    ;;
            esac
        }
        # `-S` (T29): disable `site` so no working-tree/untracked sitecustomize.py or
        # usercustomize.py runs at interpreter startup (the startup-injection bypass). PYTHONPATH
        # is the SINGLE import dir — the trusted temp dir on the normal path, $ROOT/hooks ONLY on
        # the first-adoption bootstrap fallback (HEAD genuinely lacks the enforcer). Under `-S`
        # site-packages is dropped; the script re-adds it below WITHOUT importing startup files
        # (needed for PyYAML in the trusted-policy seed).
        FR07_IMPORT_DIR="$FR07_IMPORT_DIR" FR07_TRUSTED_POLICY="$FR07_TRUSTED_POLICY" \
        FR07_REAL_ROOT="$ROOT" PYTHONPATH="$FR07_IMPORT_DIR" python3 -S - <<'PY' || exit_proto=$?
import os
import sys
from pathlib import Path
# root = the REAL repo (git --cached + working-tree state/approvals/ are read from here),
# regardless of whether the enforcement CODE was imported from HEAD (trusted) or the tree.
root = Path(os.environ["FR07_REAL_ROOT"])
import_dir = os.environ.get("FR07_IMPORT_DIR") or str(root / "hooks")
sys.path.insert(0, import_dir)


def _restore_site_packages():
    # `-S` dropped site-packages; the enforcer's policy_loader imports PyYAML. Re-add the
    # site-packages dirs WITHOUT running site.main() (which would import sitecustomize/
    # usercustomize). getsitepackages()/getusersitepackages() only RETURN paths.
    import site
    dirs = []
    try:
        dirs.extend(site.getsitepackages())
    except Exception:
        pass
    try:
        u = site.getusersitepackages()
        if u:
            dirs.append(u)
    except Exception:
        pass
    for p in dirs:
        if p and p not in sys.path:
            sys.path.append(p)


_restore_site_packages()
try:
    from shared.path_policy import (
        assert_protected_policy_loaded, evaluate, staged_change_paths,
    )
    # TRUSTED-POLICY SEED (T28/#1): when running the trusted HEAD enforcer, the classification
    # (is_protected / on_unapproved_edit) must read the TRUSTED HEAD policy, not the mutable
    # working-tree policies/protected-paths.yml a tamperer could have emptied in the same commit.
    # Seed the policy loader's cache with the trusted YAML under BOTH cache keys the enforcer
    # uses (root=None internal calls and the explicit-root assert), so every get_policy(
    # "protected-paths") returns the trusted policy while state/approvals + git stay real.
    trusted_policy = os.environ.get("FR07_TRUSTED_POLICY") or ""
    if trusted_policy:
        import yaml
        from shared import policy_loader as _pl
        policy = yaml.safe_load(Path(trusted_policy).read_text(encoding="utf-8")) or {}
        _pl._POLICY_CACHE["::protected-paths"] = policy
        _pl._POLICY_CACHE[f"{root}::protected-paths"] = policy
except BaseException as e:
    # FAIL CLOSED (T27/#3): catch BaseException, not Exception. A staged/tampered
    # path_policy.py doing `raise SystemExit(0)` / `sys.exit(0)` on import subclasses
    # BaseException, so `except Exception` let it slip through -> §3 exited 0 unguarded
    # (a self-bypass: stage the tampered module in the same commit). BaseException blocks.
    print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check could not load path_policy (import error: {e!r}).", file=sys.stderr)
    print("Refusing to commit fail-open. Fix the module/env (e.g. install the missing dep); NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
try:
    import subprocess
    # POLICY-PRESENT FAIL-CLOSED (T27/#5): a missing/empty/malformed protected-paths.yml
    # would make is_protected() always False -> FR-07 silently OFF. Refuse to run against
    # an unenforceable policy: require a mapping with a non-empty fusebase_flow_internals
    # category. Scoped to FR-07 (get_policy for other policies is untouched). Raises ->
    # the BaseException body wrapper below catches it -> BLOCK with the policy-missing text.
    assert_protected_policy_loaded(root)
    # ENUMERATION FAIL-CLOSED (T26): staged_change_paths() now RAISES on ANY subprocess
    # exception AND on a nonzero git rc (T27/#4 — it no longer returns a partial/empty
    # list), so a FAILED enumeration while staged changes exist can no longer yield
    # paths=[] -> no hits -> exit 0. The raise reaches the BaseException wrapper -> BLOCK.
    # Cross-check here too (the enforcement point; path_policy's shared contract stays
    # intact): re-list staged names with an EXPLICIT rc check. rc!=0 (or the subprocess
    # itself raising) => cannot enumerate => BLOCK. names non-empty but
    # staged_change_paths() empty => enumeration disagreement => BLOCK. rc0 + no staged
    # names is the LEGITIMATE no-op (must still PASS).
    try:
        lp = subprocess.run(
            ["git", "diff", "--cached", "--name-only"],
            capture_output=True, text=True, cwd=str(root),
        )
        list_rc = lp.returncode
        names = [n for n in lp.stdout.splitlines() if n]
    except Exception:
        list_rc, names = 1, []
    if list_rc != 0:
        print("[fusebase-flow:pre-commit] BLOCK — FR-07 could not list staged changes (git rc != 0) — failing closed.", file=sys.stderr)
        print("Refusing to commit fail-open on an unverifiable protected-path check; NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
    paths = staged_change_paths(root)
    if names and not paths:
        print("[fusebase-flow:pre-commit] BLOCK — FR-07 staged changes present but protected-path enumeration returned nothing — failing closed.", file=sys.stderr)
        print("Refusing to commit fail-open; the enumeration disagrees with the staged set. Fix the env; NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
    hits = []
    for p in paths:
        pd = evaluate(p)
        if pd.protected and not pd.has_exception:
            hits.append(pd)
except SystemExit as se:
    # T27/#3 — the SystemExit split. This §3 block itself calls sys.exit(1) for a genuine
    # BLOCK (git-rc / enumeration-disagreement / real protected-hit below). Those NONZERO
    # exits must propagate as-is. But a staged/tampered path_policy whose import or
    # evaluate()/staged_change_paths() does `raise SystemExit(0)` / `sys.exit(0)` would,
    # under a bare `raise`, exit 0 and slip the protected edit through (self-bypass). So:
    # re-raise a NONZERO SystemExit (our own BLOCK), but a code-0 SystemExit is treated as
    # the fail-open attack -> rewrite it to a hard BLOCK (exit 1). A `None` code == 0.
    code = se.code if isinstance(se.code, int) else (0 if se.code is None else 1)
    if code != 0:
        raise
    print("[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check attempted a clean exit(0) from inside the check (tampered/short-circuited path_policy) — failing closed.", file=sys.stderr)
    print("Refusing to commit fail-open; a security control must never self-exit 0. Fix the module/env; NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
except BaseException as e:
    # FAIL CLOSED (T27/#3): catch BaseException, not Exception. Any other non-Exception
    # error (KeyboardInterrupt-class, etc.) inside the check blocks rather than waving the
    # edit through. (A clean no-hit falls through to the natural exit 0 below.)
    print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check errored ({e!r}).", file=sys.stderr)
    print("Refusing to commit fail-open. Fix the check/env; NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
if hits:
    print("[fusebase-flow:pre-commit] BLOCK — protected paths edited without exception artifact:", file=sys.stderr)
    for h in hits:
        print(f"  {h.path}  (category={h.category})", file=sys.stderr)
    print("Per FR-07: author an approval artifact at state/approvals/ first.", file=sys.stderr)
    sys.exit(1)
PY
        # Clean up the trusted-HEAD temp package (FR-27 no-runaways: bounded, always
        # removed) BEFORE acting on the rc so a BLOCK never leaks the temp dir.
        [ -n "$FR07_TMP" ] && rm -rf "$FR07_TMP"
        if [ "${exit_proto:-0}" -ne 0 ]; then exit 1; fi
    else
        # python3 absent + staged changes: DON'T silently skip FR-07. Loud warn (not a
        # hard block — a python3-less env must still commit; §2's secret scan already
        # gates on python3) so the un-enforceable gap is visible, never silent.
        echo "[fusebase-flow:pre-commit] WARN — python3 not found; FR-07 protected-path check was NOT enforced for this commit. Install python3 to enforce FR-07." >&2
    fi
fi

# 4. Module-size ratchet (FR-25). Warn-only until policies/module-size-baseline.txt
#    is committed; then over-ceiling growth blocks (extract or operator exemption).
if [ -f "$ROOT/hooks/local/check-module-size.sh" ]; then
    if ! bash "$ROOT/hooks/local/check-module-size.sh" --staged; then
        echo "[fusebase-flow:pre-commit] BLOCK — module-size ratchet failed (FR-25)." >&2
        exit 1
    fi
fi

# 5. Lint + typecheck (FR-13). Project hooks may set FUSEBASE_FLOW_LINT / FUSEBASE_FLOW_TYPECHECK.
LINT_CMD="${FUSEBASE_FLOW_LINT:-}"
TYPECHECK_CMD="${FUSEBASE_FLOW_TYPECHECK:-}"

# Auto-detect node project lint/typecheck if env vars are unset.
if [ -z "$LINT_CMD" ] && [ -f package.json ] && grep -q '"lint"' package.json; then
    LINT_CMD="npm run -s lint"
fi
if [ -z "$TYPECHECK_CMD" ] && [ -f package.json ] && grep -q '"typecheck"' package.json; then
    TYPECHECK_CMD="npm run -s typecheck"
fi

if [ -n "$LINT_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running lint: $LINT_CMD" >&2
    if ! eval "$LINT_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — lint failed (FR-13)." >&2
        exit 1
    fi
fi

if [ -n "$TYPECHECK_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running typecheck: $TYPECHECK_CMD" >&2
    if ! eval "$TYPECHECK_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — typecheck failed (FR-13)." >&2
        exit 1
    fi
fi

echo "[fusebase-flow:pre-commit] all checks passed" >&2
exit 0
