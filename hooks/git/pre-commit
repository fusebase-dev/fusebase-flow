#!/usr/bin/env bash
# Fusebase Flow — pre-commit git hook
# fusebase-flow-managed-hook: v1
#
# Runs before each commit. Defends FR-07 (worker-undisturbed), FR-12 (secrets),
# FR-13 (lint+typecheck), and FR-25 (module-size ratchet). Original Fusebase
# Flow content; clean-room.
#
# Install: bash hooks/local/install-git-hooks.sh
#
# Bypass: NEVER use --no-verify. Real secret flagged => rotate + `git reset HEAD --
# <file>` to unstage; never whitelist it (disables a pattern globally, breaks the
# scanner's own fixtures 10/11). False positive => fix the pattern.
# Known scan-scope limits (docs/compatibility.md § Secret-scan): designed-token
# files are path-excluded; PreToolUse self-trips when an agent writes full
# secret-patterns.yml content.

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
    echo "[fusebase-flow:pre-commit] not in a git repo; skipping" >&2
    exit 0
fi

cd "$ROOT" || exit 0

# 1. Reject likely secret files in staged changes.
SECRETS_REGEX='\.env$|\.env\.[^\.]*$|credentials\.json$|/secrets/|\.pem$|\.key$|\.netrc$'
STAGED_PATHS="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"
SECRET_HITS="$(echo "$STAGED_PATHS" | grep -E "$SECRETS_REGEX" || true)"
if [ -n "$SECRET_HITS" ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — secret-like files staged:" >&2
    echo "$SECRET_HITS" | sed 's/^/  /' >&2
    echo "Per FR-12: never commit secrets. Unstage with \`git reset HEAD -- <file>\` and rotate if leaked." >&2
    exit 1
fi

# 2. Secret content scan: ONLY added (+) lines, designed-token files path-excluded
#    (D-A1 — secret-patterns.yml self-trip + whitelist trap). Helper, not inline
#    bash string-parsing: hooks/shared/staged_secret_scan.py. scan() is UNCHANGED.
if command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$ROOT/hooks" python3 "$ROOT/hooks/shared/staged_secret_scan.py" || exit_secret=$?
    if [ "${exit_secret:-0}" -ne 0 ]; then exit 1; fi
fi

# 3. Reject protected-path edits without an active exception artifact. Covers the
#    FULL staged change set — ADDS/MODS *and* DELETES + RENAMES (a `git rm` or rename
#    of a protected file must reach path_policy too; the old ACM-only set let deletes/
#    rename-sources through with exit 0 — the shipped FR-07 bypass). The gate fires on
#    ANY staged change (unfiltered), not just ACM. §1/§2 secret checks stay ACM by
#    design (deleting a file can't leak a secret).
#    This is a SECURITY control: it FAILS CLOSED. An import error (missing dep, broken/
#    tampered path_policy, a syntax error introduced in the SAME commit) or any unexpected
#    error inside the check EXITS 1 (block) — never exit 0. A silent fail-open would let a
#    protected edit through the moment path_policy can't load. python3 absent + staged
#    changes => a LOUD warn (not a hard block: a python3-less env must still be able to
#    commit, and §2 already gates on python3), so the un-enforceable gap is never silent.
# #1 (T27): capture the OUTER git-list rc too (mirrors the inner python rc-check). A
# nonzero rc here means we can't reliably know whether protected paths are staged, so
# fail closed rather than skip §3 on an empty-because-broken list. (Non-reachable in a
# healthy repo — a broken repo won't commit — but cheap and consistent.)
STAGED_ANY="$(git diff --cached --name-only 2>/dev/null)"; STAGED_ANY_RC=$?
if [ "$STAGED_ANY_RC" -ne 0 ]; then
    echo "[fusebase-flow:pre-commit] BLOCK — FR-07 could not list staged changes (outer git rc=$STAGED_ANY_RC) — failing closed." >&2
    echo "Refusing to commit fail-open on an unverifiable protected-path check; NEVER use --no-verify." >&2
    exit 1
fi
if [ -n "$STAGED_ANY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        PYTHONPATH="$ROOT/hooks" python3 - <<'PY' || exit_proto=$?
import sys
from pathlib import Path
root = Path.cwd()
sys.path.insert(0, str(root / "hooks"))
try:
    from shared.path_policy import (
        assert_protected_policy_loaded, evaluate, staged_change_paths,
    )
except BaseException as e:
    # FAIL CLOSED (T27/#3): catch BaseException, not Exception. A staged/tampered
    # path_policy.py doing `raise SystemExit(0)` / `sys.exit(0)` on import subclasses
    # BaseException, so `except Exception` let it slip through -> §3 exited 0 unguarded
    # (a self-bypass: stage the tampered module in the same commit). BaseException blocks.
    print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check could not load path_policy (import error: {e!r}).", file=sys.stderr)
    print("Refusing to commit fail-open. Fix the module/env (e.g. install the missing dep); NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
try:
    import subprocess
    # POLICY-PRESENT FAIL-CLOSED (T27/#5): a missing/empty/malformed protected-paths.yml
    # would make is_protected() always False -> FR-07 silently OFF. Refuse to run against
    # an unenforceable policy: require a mapping with a non-empty fusebase_flow_internals
    # category. Scoped to FR-07 (get_policy for other policies is untouched). Raises ->
    # the BaseException body wrapper below catches it -> BLOCK with the policy-missing text.
    assert_protected_policy_loaded(root)
    # ENUMERATION FAIL-CLOSED (T26): staged_change_paths() now RAISES on ANY subprocess
    # exception AND on a nonzero git rc (T27/#4 — it no longer returns a partial/empty
    # list), so a FAILED enumeration while staged changes exist can no longer yield
    # paths=[] -> no hits -> exit 0. The raise reaches the BaseException wrapper -> BLOCK.
    # Cross-check here too (the enforcement point; path_policy's shared contract stays
    # intact): re-list staged names with an EXPLICIT rc check. rc!=0 (or the subprocess
    # itself raising) => cannot enumerate => BLOCK. names non-empty but
    # staged_change_paths() empty => enumeration disagreement => BLOCK. rc0 + no staged
    # names is the LEGITIMATE no-op (must still PASS).
    try:
        lp = subprocess.run(
            ["git", "diff", "--cached", "--name-only"],
            capture_output=True, text=True, cwd=str(root),
        )
        list_rc = lp.returncode
        names = [n for n in lp.stdout.splitlines() if n]
    except Exception:
        list_rc, names = 1, []
    if list_rc != 0:
        print("[fusebase-flow:pre-commit] BLOCK — FR-07 could not list staged changes (git rc != 0) — failing closed.", file=sys.stderr)
        print("Refusing to commit fail-open on an unverifiable protected-path check; NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
    paths = staged_change_paths(root)
    if names and not paths:
        print("[fusebase-flow:pre-commit] BLOCK — FR-07 staged changes present but protected-path enumeration returned nothing — failing closed.", file=sys.stderr)
        print("Refusing to commit fail-open; the enumeration disagrees with the staged set. Fix the env; NEVER use --no-verify.", file=sys.stderr)
        sys.exit(1)
    hits = []
    for p in paths:
        pd = evaluate(p)
        if pd.protected and not pd.has_exception:
            hits.append(pd)
except SystemExit as se:
    # T27/#3 — the SystemExit split. This §3 block itself calls sys.exit(1) for a genuine
    # BLOCK (git-rc / enumeration-disagreement / real protected-hit below). Those NONZERO
    # exits must propagate as-is. But a staged/tampered path_policy whose import or
    # evaluate()/staged_change_paths() does `raise SystemExit(0)` / `sys.exit(0)` would,
    # under a bare `raise`, exit 0 and slip the protected edit through (self-bypass). So:
    # re-raise a NONZERO SystemExit (our own BLOCK), but a code-0 SystemExit is treated as
    # the fail-open attack -> rewrite it to a hard BLOCK (exit 1). A `None` code == 0.
    code = se.code if isinstance(se.code, int) else (0 if se.code is None else 1)
    if code != 0:
        raise
    print("[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check attempted a clean exit(0) from inside the check (tampered/short-circuited path_policy) — failing closed.", file=sys.stderr)
    print("Refusing to commit fail-open; a security control must never self-exit 0. Fix the module/env; NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
except BaseException as e:
    # FAIL CLOSED (T27/#3): catch BaseException, not Exception. Any other non-Exception
    # error (KeyboardInterrupt-class, etc.) inside the check blocks rather than waving the
    # edit through. (A clean no-hit falls through to the natural exit 0 below.)
    print(f"[fusebase-flow:pre-commit] BLOCK — FR-07 protected-path check errored ({e!r}).", file=sys.stderr)
    print("Refusing to commit fail-open. Fix the check/env; NEVER use --no-verify.", file=sys.stderr)
    sys.exit(1)
if hits:
    print("[fusebase-flow:pre-commit] BLOCK — protected paths edited without exception artifact:", file=sys.stderr)
    for h in hits:
        print(f"  {h.path}  (category={h.category})", file=sys.stderr)
    print("Per FR-07: author an approval artifact at state/approvals/ first.", file=sys.stderr)
    sys.exit(1)
PY
        if [ "${exit_proto:-0}" -ne 0 ]; then exit 1; fi
    else
        # python3 absent + staged changes: DON'T silently skip FR-07. Loud warn (not a
        # hard block — a python3-less env must still commit; §2's secret scan already
        # gates on python3) so the un-enforceable gap is visible, never silent.
        echo "[fusebase-flow:pre-commit] WARN — python3 not found; FR-07 protected-path check was NOT enforced for this commit. Install python3 to enforce FR-07." >&2
    fi
fi

# 4. Module-size ratchet (FR-25). Warn-only until policies/module-size-baseline.txt
#    is committed; then over-ceiling growth blocks (extract or operator exemption).
if [ -f "$ROOT/hooks/local/check-module-size.sh" ]; then
    if ! bash "$ROOT/hooks/local/check-module-size.sh" --staged; then
        echo "[fusebase-flow:pre-commit] BLOCK — module-size ratchet failed (FR-25)." >&2
        exit 1
    fi
fi

# 5. Lint + typecheck (FR-13). Project hooks may set FUSEBASE_FLOW_LINT / FUSEBASE_FLOW_TYPECHECK.
LINT_CMD="${FUSEBASE_FLOW_LINT:-}"
TYPECHECK_CMD="${FUSEBASE_FLOW_TYPECHECK:-}"

# Auto-detect node project lint/typecheck if env vars are unset.
if [ -z "$LINT_CMD" ] && [ -f package.json ] && grep -q '"lint"' package.json; then
    LINT_CMD="npm run -s lint"
fi
if [ -z "$TYPECHECK_CMD" ] && [ -f package.json ] && grep -q '"typecheck"' package.json; then
    TYPECHECK_CMD="npm run -s typecheck"
fi

if [ -n "$LINT_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running lint: $LINT_CMD" >&2
    if ! eval "$LINT_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — lint failed (FR-13)." >&2
        exit 1
    fi
fi

if [ -n "$TYPECHECK_CMD" ]; then
    echo "[fusebase-flow:pre-commit] running typecheck: $TYPECHECK_CMD" >&2
    if ! eval "$TYPECHECK_CMD"; then
        echo "[fusebase-flow:pre-commit] BLOCK — typecheck failed (FR-13)." >&2
        exit 1
    fi
fi

echo "[fusebase-flow:pre-commit] all checks passed" >&2
exit 0
