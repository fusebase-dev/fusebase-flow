# Fusebase Flow runtime state — never commit the contents (but keep dirs via .gitkeep)
state/audit.log.jsonl
state/context-summary.md
state/*.tmp
state/approvals/*
!state/approvals/.gitkeep
# health_check_deferral-*.json artifacts are documents of record (90-day TTL,
# operator-authored deferral decisions). They MUST be in git so fresh clones
# reproduce the EXCEPTION_IN_EFFECT verdict and PR review can audit which
# deferrals are active. Other state/approvals/* artifacts (e.g.
# production_deploy-*.json — 60-min ephemeral auth tokens) stay gitignored.
# See docs/health-check-deferrals.md and docs/release-notes/v2.6.1.md.
!state/approvals/health_check_deferral-*.json
!state/.gitkeep
state/audit/*
!state/audit/.gitkeep

# Local overrides of committed policies (committed defaults live at policies/*.yml;
# a committed *.local.yml could silently neutralize gates for every clone)
policies/approval-policy.local.yml
policies/*.local.yml

# Secrets / env
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json

# OS
.DS_Store
Thumbs.db

# Editors (project-specific config not needed in template)
.vscode/
.idea/

# Python (hooks runtime)
__pycache__/
*.pyc
*.pyo

# Node (when projects layered on top use it)
node_modules/
dist/
build/
*.log

# Local-only docs (operator working notes; never published to GitHub)
docs/fusebase-health/

# Defensive: hook handlers running with wrong cwd previously created
# .fusebase-flow/state/audit.log.jsonl. Standard runtime state lives in state/.
.fusebase-flow/
